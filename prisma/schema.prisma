generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id Int @id @default(autoincrement())
  title String
  content String
  sumarry String
  userId Int 
  // user  
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt
  quizzes Quiz[]
}

model Quiz {
  id Int @id @default(autoincrement())
  question String
  options String[]
  answer String
  articleId Int 
  article Article @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt
}